# Leave unset in local development to use the Vite /api proxy.
# Set this only when you want the browser to call an API host directly.
# VITE_API_BASE_URL=http://localhost:5101

# Leave unset in local development to use the Vite /engine proxy.
# Set this only when you want the browser to call the Rust engine directly.
# VITE_ENGINE_BASE_URL=http://localhost:7071
